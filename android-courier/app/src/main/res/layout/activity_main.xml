<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Globus Courier"
            android:textColor="@color/text"
            android:textSize="24sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/card_glass"
            android:orientation="vertical"
            android:padding="14dp">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Courier token yoki QR link"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="@color/primary"
                app:hintTextColor="@color/muted">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/tokenInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textColor="@color/text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Kuryer ismi"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="@color/primary"
                app:hintTextColor="@color/muted">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/courierNameInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"
                    android:textColor="@color/text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Kuryer telefoni"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="@color/primary"
                app:hintTextColor="@color/muted">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/courierPhoneInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="phone"
                    android:textColor="@color/text" />
            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/saveTokenBtn"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:background="@drawable/button_secondary"
                    android:text="Tokenni saqlash"
                    android:textAllCaps="false"
                    android:textColor="@color/text" />

                <Button
                    android:id="@+id/scanQrBtn"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/button_secondary"
                    android:text="QR scan"
                    android:textAllCaps="false"
                    android:textColor="@color/text" />
            </LinearLayout>

            <Button
                android:id="@+id/loadOrderBtn"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/button_primary"
                android:text="Aktiv buyurtmani yuklash"
                android:textAllCaps="false"
                android:textColor="#041D23"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/card_glass"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/orderInfoText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Buyurtma ma'lumotlari shu yerda ko'rsatiladi"
                android:textColor="@color/text"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Status: -"
                android:textColor="@color/muted" />

            <Button
                android:id="@+id/openMapsBtn"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/button_secondary"
                android:text="Google Maps’da ochish"
                android:textAllCaps="false"
                android:textColor="@color/text" />

            <Button
                android:id="@+id/acceptBtn"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/button_primary"
                android:text="Buyurtmani qabul qildim"
                android:textAllCaps="false"
                android:textColor="#041D23"
                android:textStyle="bold" />

            <Button
                android:id="@+id/deliverBtn"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/button_secondary"
                android:text="Mijozga topshirildi"
                android:textAllCaps="false"
                android:textColor="@color/text" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
